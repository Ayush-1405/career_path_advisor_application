# Server Configuration
SERVER_PORT=8080

# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/career_advisor
DB_USERNAME=root
DB_PASSWORD=

# Email Configuration (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEBUG=true

# Security Configuration
JWT_SECRET=your_32_char_long_random_jwt_secret_key_here
JWT_EXPIRATION_MS=86400000

# External Services
WIT_AI_TOKEN=YOUR_WIT_AI_SERVER_ACCESS_TOKEN

# CORS Configuration (Comma separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:3000,http://127.0.0.1:5500
